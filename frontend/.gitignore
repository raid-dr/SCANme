# Git ignore rules for the frontend workspace.
# Prevents generated files and editor artifacts from being committed.

node_modules/   # Installed npm dependencies (re-created by `npm install`).
dist/           # Vite's production build output (regenerated by `npm run build`).
.vite/          # Vite cache directory.
*.log           # Any log files produced by npm or the dev server.
.DS_Store       # macOS Finder metadata (harmless but noisy).
